{
  "compilerOptions": {
    // Module Configuration
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    // Module Interop
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    // Source Maps & Declaration
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    // Path Configuration
    "baseUrl": ".",
    "outDir": "dist",
    "rootDir": ".",
    // Type Checking
    "strict": true,
    "noImplicitAny": true,
    "skipLibCheck": true,
    // Decorators
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    // Additional Checks
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    // Path Aliases
    "paths": {
      "@/*": [
        "src/*"
      ]
    }
  },
  "include": [
    "src/**/*",
    "test/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}